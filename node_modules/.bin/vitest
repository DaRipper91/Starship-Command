#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/app/node_modules/.pnpm/vitest@4.1.9_@types+node@20.19.43_@vitest+coverage-v8@4.1.9_jsdom@29.1.1_vite@7.3.6_@ty_4373a5278a222bb4581aa439ee5d5b7d/node_modules/vitest/node_modules:/app/node_modules/.pnpm/vitest@4.1.9_@types+node@20.19.43_@vitest+coverage-v8@4.1.9_jsdom@29.1.1_vite@7.3.6_@ty_4373a5278a222bb4581aa439ee5d5b7d/node_modules:/app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/app/node_modules/.pnpm/vitest@4.1.9_@types+node@20.19.43_@vitest+coverage-v8@4.1.9_jsdom@29.1.1_vite@7.3.6_@ty_4373a5278a222bb4581aa439ee5d5b7d/node_modules/vitest/node_modules:/app/node_modules/.pnpm/vitest@4.1.9_@types+node@20.19.43_@vitest+coverage-v8@4.1.9_jsdom@29.1.1_vite@7.3.6_@ty_4373a5278a222bb4581aa439ee5d5b7d/node_modules:/app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vitest/vitest.mjs" "$@"
else
  exec node  "$basedir/../vitest/vitest.mjs" "$@"
fi
